{
  "name": "@avaliemob/backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=server.js --format=cjs --external:express --external:cors --external:'@trpc/server' --external:dotenv --external:mysql2 --external:drizzle-orm --external:bcryptjs --external:jsonwebtoken --external:uuid --external:openai --external:axios --external:zod --external:docx --external:fsevents",
    "start": "node server.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "@trpc/server": "^10.45.0",
    "@trpc/client": "^10.45.0",
    "@avaliemob/db": "file:../db",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.28.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.0",
    "openai": "^4.28.0",
    "uuid": "^9.0.1",
    "docx": "^8.5.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "eslint": "^8.55.0"
  }
}
